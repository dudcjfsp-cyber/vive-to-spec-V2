# Frontend mode
VITE_APP_MODE=managed
VITE_MANAGED_API_BASE_URL=http://127.0.0.1:8787/api

# Optional deploy target override
# Leave unset for normal local development.
# Vercel detects its own environment automatically.
# VITE_DEPLOY_TARGET=vercel

# Managed API server keys (server terminal)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional managed API server settings
# Local dev server defaults to 0.0.0.0:8787.
# Vercel production uses the functions in /api and ignores host/port.
# MANAGED_API_HOST=0.0.0.0
# MANAGED_API_PORT=8787
# MANAGED_API_PREFIX=/api
# MANAGED_API_ALLOWED_ORIGIN=http://127.0.0.1:5173
